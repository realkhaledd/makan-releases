{
  "name": "makan-property-os",
  "productName": "MAKAN Property OS",
  "version": "1.0.5",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build && mv dist/index.html dist/app.html",
    "preview": "vite preview",
    "electron:build": "vite build && electron-builder",
    "electron:build:mac": "npm run build && electron-builder --mac"
  },
  "build": {
    "appId": "com.realkhalid.makan-property-os",
    "productName": "MAKAN Property OS",
    "copyright": "© 2025 REAL KHALED",
    "publish": {
      "provider": "github",
      "owner": "realkhaledd",
      "repo": "makan-releases",
      "private": false
    },
    "directories": {
      "output": "release",
      "buildResources": "build-resources"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "MAKAN Property OS",
      "contents": [
        {
          "x": 150,
          "y": 200
        },
        {
          "x": 400,
          "y": 200,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 560,
        "height": 360
      }
    }
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc10",
    "cors": "^2.8.6",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "firebase": "^12.12.1",
    "lucide-react": "^1.12.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "whatsapp-web.js": "^1.34.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "vite": "^8.0.10"
  }
}
